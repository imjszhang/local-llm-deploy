{
  "example-chat": {
    "full_model_name": "示例对话模型（请改名并改 repo_id）",
    "repo_id": "unsloth/Your-Model-GGUF",
    "download_source": "modelscope",
    "default_quant": "Q4_K_M",
    "alias": "unsloth/Your-Model",
    "default_port": 8001,
    "quants": {
      "Q4_K_M": {
        "pattern": "*.gguf",
        "size_gb": 10
      }
    },
    "params": {
      "temp": 0.8,
      "top_p": 0.95,
      "ctx_size": 8192,
      "n_predict": 4096,
      "repeat_penalty": 1.0,
      "max_concurrent": 2,
      "kv_budget_ratio": 0.9,
      "extra_args": []
    }
  },
  "jina-embed": {
    "type": "embedding",
    "download_source": "modelscope",
    "repo_id": "jinaai/jina-embeddings-v5-text-small",
    "repo_name": "jinaai-jina-embeddings-v5-text-small",
    "alias": "jina-embeddings-v5-text-small",
    "default_port": 8004,
    "params": {
      "dimensions": 1024,
      "default_task": "text-matching"
    }
  },
  "whisper-large-v3": {
    "type": "asr",
    "full_model_name": "Whisper Large V3 (MLX)",
    "download_source": "huggingface",
    "repo_id": "mlx-community/whisper-large-v3-mlx",
    "repo_name": "mlx-community-whisper-large-v3-mlx",
    "alias": "whisper-large-v3",
    "default_port": 8007,
    "download_allow_patterns": ["*.json", "*.npz", "*.safetensors", "*.txt", "tokenizer*"],
    "params": {
      "language": "zh",
      "task": "transcribe",
      "response_format": "json"
    }
  },
  "ds4flash": {
    "type": "external",
    "full_model_name": "DeepSeek V4 Flash (ds4-server)",
    "repo_id": "local/ds4-server",
    "alias": "deepseek-v4-flash",
    "default_port": 8005,
    "external_backend": true,
    "startup_hint": "在 ds4 仓库执行 scripts/ds4-server-mac-studio-512g.sh（默认 DS4_PORT=8005，模型 DS4_MODEL=ds4flash.gguf）",
    "params": {
      "ctx_size": 1048576,
      "n_predict": 393216,
      "max_concurrent": 2,
      "kv_budget_ratio": 0.85
    }
  }
}
